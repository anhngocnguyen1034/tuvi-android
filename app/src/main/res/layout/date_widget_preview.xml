<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/date_widget_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- HÀNG 1: THỨ VÀ NGÀY DƯƠNG LỊCH (Chữ in hoa, đậm, hiện đại) -->
    <TextView
        android:id="@+id/tv_solar_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="THỨ NĂM, 09 THÁNG 07"
        android:textColor="#FF1A1A2E"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.02" />

    <!-- HÀNG 2: NGÀY ÂM LỊCH & NĂM (Chữ thường, thanh lịch) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_lunar_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25 tháng 05 (Âm lịch)"
            android:textColor="#FF4A4A5A"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" • "
            android:textColor="#FF8A8A9A"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_lunar_year"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Năm Bính Ngọ"
            android:textColor="#FF6B6B7B"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- ĐƯỜNG PHÂN CÁCH MẢNH (Kéo ngang tỷ lệ đẹp) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="14dp"
        android:background="#22000000" />

    <!-- HÀNG 3: CÂU QUOTES (Chữ nghiêng, truyền cảm hứng) -->
    <TextView
        android:id="@+id/tv_quote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&quot;Hành trình vạn dặm luôn khởi đầu từ một bước chân.&quot;"
        android:textColor="#FF555565"
        android:textSize="13sp"
        android:textStyle="italic"
        android:lineSpacingMultiplier="1.2" />

</LinearLayout>